bridgelab.net {
    handle /api/* {
        reverse_proxy api:3001
    }

    handle {
        root * /srv
        encode gzip zstd

        @wasm path *.wasm
        header @wasm Cache-Control "public, max-age=31536000, immutable"

        @assets path /assets/*
        header @assets Cache-Control "public, max-age=31536000, immutable"

        @dds path /dds/*
        header @dds Cache-Control "public, max-age=31536000, immutable"

        @guides path /guides/*
        header @guides Cache-Control "public, max-age=86400"

        @learn path /learn/*
        header @learn Cache-Control "public, max-age=86400"

        header /index.html Cache-Control "public, max-age=3600"

        try_files {path} /index.html
        file_server
    }
}
