{
  "moduleId": "stayman-garbage",
  "displayName": "Garbage Stayman",
  "category": "notrump-responses",
  "defaultRole": "responder",
  "fixtureVersion": 1,
  "variantOf": "stayman",
  "description": "Bid 2C over 1NT as Garbage Stayman to escape with a weak short-club hand; after a 2D denial, Crawling Stayman lets opener pass 2H or correct to 2S.",
  "purpose": "Use Stayman only as a weak escape after 1NT, passing a playable 2D/2H/2S partscore or, with both majors and short diamonds, rebidding 2H so opener can choose the better major.",
  "references": {
    "authority": {
      "url": "https://www.larryco.com/bridge-articles/notrump-opening-bids-part-1-of-3-footnote-1",
      "label": "Larry Cohen — Stayman Continuations / Garbage Stayman (bridge-articles/notrump-opening-bids-part-1-of-3-footnote-1)"
    },
    "discovery": {
      "url": "https://www.bridgebum.com/garbage_stayman.php"
    }
  },
  "teaching": {
    "tradeoff": "Garbage Stayman gives up constructive Stayman on these weak hands so the partnership can escape 1NT into the least dangerous partscore.",
    "principle": "Use 2C only with a weak short-club escape shape; pass 2H or 2S, pass 2D when diamonds are safe, and over 2D crawl to 2H only with both majors and short diamonds.",
    "commonMistakes": [
      {
        "text": "Do not use Garbage Stayman with a weak 5-card major.",
        "reason": "Those hands belong to Jacoby transfers, not to the short-club garbage escape."
      },
      {
        "text": "Do not rebid 2H over 2D unless you have both majors and short diamonds.",
        "reason": "Crawling Stayman asks opener to pass hearts or correct to spades; without both majors, the rescue loses its point."
      },
      {
        "text": "Do not treat Garbage Stayman as constructive Stayman.",
        "reason": "This module is only the weak escape and crawling follow-up; invitational and game-forcing Stayman auctions belong in the regular Stayman module."
      }
    ]
  },
