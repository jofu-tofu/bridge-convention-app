{
  "moduleId": "natural-bids",
  "displayName": "Natural Bids",
  "category": "opening-bids",
  "fixtureVersion": 1,
  "description": "Standard natural bids: one-level opening bids and natural notrump invite/game raises. This is an umbrella baseline — responder actions to 1-of-a-suit openings and opener rebid continuations are intentionally out of scope for this module and are handled by dedicated response/opening modules.",
  "purpose": "Learn the baseline one-level opening bids and natural notrump raises that apply when no specialized convention changes the meaning of a call",
  "references": {
    "authority": {
      "url": "https://en.wikipedia.org/wiki/Standard_American_Yellow_Card",
      "label": "ACBL SAYC — natural bidding rules are defined by the base system"
    },
    "discovery": {
      "url": "https://www.bridgebum.com/sayc.php"
    }
  },
  "teaching": {
    "tradeoff": "There is no special tradeoff here — these bids keep their usual natural meanings",
    "principle": "When no major fit exists, raise notrump to the level your combined HCP supports — 25 total for game.",
    "commonMistakes": [
      {
        "text": "Don't jump to three notrump with a worthless doubleton — consider whether a suit contract might play better",
        "reason": "Notrump games need controls on the side suits; a bare doubleton in responder's hand can concede the first trick and set up a long suit for the defence."
      },
      {
        "text": "With a flat invitational hand, raise to two notrump rather than stretching to game with marginal values",
        "reason": "Opposite a minimum one notrump opening, game is poor on barely-invitational values; responder should let opener accept or decline."
      },
      {
        "text": "Treat one club as possibly three cards in a four-four-three-two or four-three-three-three hand; do not play responder for four-plus clubs",
        "reason": "With four-four in the majors and three-two in the minors, opener must bid one club because one diamond would promise four; the short-club convention keeps the opening natural without misrepresenting club length."
      }
    ]
  },
