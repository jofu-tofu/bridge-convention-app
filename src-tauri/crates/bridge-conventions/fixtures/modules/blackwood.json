{
  "moduleId": "blackwood",
  "description": "Use 4NT to ask for aces when considering slam",
  "purpose": "Determine whether the partnership has enough aces to bid slam safely",
  "teaching": {
    "tradeoff": "Using 4NT as Blackwood means you can't use it as a natural quantitative raise to slam.",
    "principle": "Before bidding slam, check for aces — missing two aces means the opponents can cash two tricks immediately.",
    "commonMistakes": [
      "Don't bid Blackwood without an agreed trump fit — you need a fit before asking for aces",
      "5NT king ask guarantees all four aces are accounted for — never bid 5NT missing an ace"
    ]
  },
