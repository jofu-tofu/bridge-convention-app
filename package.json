{
  "name": "bridge-practice-app",
  "version": "0.1.0",
  "description": "Bridge convention practice app — drill Stayman, Gerber, DONT, Bergen Raises",
  "type": "module",
  "scripts": {
    "wasm:build": "wasm-pack build src-tauri/crates/bridge-wasm --target web --out-dir pkg",
    "wasm:dev": "wasm-pack build src-tauri/crates/bridge-wasm --target web --out-dir pkg --dev",
    "wasm:ensure": "bash scripts/ensure-wasm.sh",
    "dds:build": "bash scripts/build-dds-wasm.sh",
    "dds:ensure": "bash scripts/ensure-dds.sh",
    "dev": "npm run wasm:ensure && npm run dds:ensure && vite dev",
    "build": "npm run wasm:build && npm run dds:ensure && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "pretest": "npm run wasm:ensure",
    "test": "vitest",
    "pretest:run": "npm run wasm:ensure",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "lint": "eslint src tests *.js *.ts",
    "lint:fix": "eslint src tests *.js *.ts --fix",
    "lint:dead": "knip --files",
    "lint:full": "npm run lint && npm run lint:dead",
    "lint:tiers": "tsx scripts/lint-tiers.ts",
    "test:tier-report": "tsx scripts/lint-tiers.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.0.1",
    "eslint-plugin-svelte": "^3.15.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^25.0.0",
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "5.43.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.3",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
