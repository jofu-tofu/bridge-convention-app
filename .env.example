# Bridge Lab — environment template.
# Copy to `.env` for local dev (already gitignored).
# Copy to the VPS and fill with LIVE values for production.
# Never commit a filled .env.

# =============================================================================
# Core app URLs / database
# =============================================================================
# Safe default matches the current Rust fallback.
# Dev:  sqlite:///data/bridge.db
# Prod: sqlite:///data/bridge.db unless you intentionally move the mounted DB path.
DATABASE_URL=sqlite:///data/bridge.db

# Safe default matches the current Rust fallback.
# Dev:  http://localhost:1420
# Prod: https://<your-domain>
BASE_URL=http://localhost:1420

# =============================================================================
# OAuth (shared by both envs — but use different OAuth apps per env)
# =============================================================================
# Dev: register OAuth app with localhost callback URL.
# Prod: register a separate OAuth app with https://<your-domain>/... callback.
# Google:  https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Stripe
# =============================================================================
# Dev:  sk_test_...  from Stripe sandbox (Developers → API keys, test mode).
# Prod: sk_live_...  from the activated live account. NEVER put live keys on a laptop.
STRIPE_SECRET_KEY=

# Dev:  whsec_...  printed by `stripe listen --forward-to localhost:3001/api/billing/webhook`.
#                   Stable per machine — set once, leave it.
# Prod: whsec_...  from Dashboard → Developers → Webhooks → (your endpoint) → Signing secret.
#                   Different from dev. Stable forever unless you click "Roll secret".
STRIPE_WEBHOOK_SECRET=

# Dev:  price_...  from sandbox. Currently: price_1TLQlyFbEF2nKpYobLX2zqm8 (Bridge Lab Premium, $5.99/mo).
# Prod: price_...  must be RECREATED in live mode. Sandbox IDs don't exist in live.
STRIPE_PRICE_ID_MONTHLY=

# Dev:  price_...  optional annual sandbox price if enabled for testing.
# Prod: price_...  separate live-mode annual price ID. Recreate it in live if annual billing ships.
STRIPE_PRICE_ID_ANNUAL=

# Dev:  http://localhost:1420/billing/success  and  /billing/cancel
# Prod: https://<your-domain>/billing/success  and  /billing/cancel  (HTTPS required by Stripe for live).
BILLING_SUCCESS_URL=
BILLING_CANCEL_URL=

# =============================================================================
# Conventions fixtures (Phase 3)
# =============================================================================
# Dev:  leave UNSET to use the repo-relative fallback.
# Prod: the API image already sets `/app/fixtures`; only add this if you need an explicit override.
# CONVENTIONS_FIXTURES_DIR=/app/fixtures
