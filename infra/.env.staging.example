# Local staging env — copy to infra/.env.staging and fill in real test-mode secrets.
# NEVER commit .env.staging. Add it to .gitignore if not already covered.

# --- Base ---
BASE_URL=https://localhost
CORS_ALLOWED_ORIGINS=https://localhost
DATABASE_URL=sqlite:///data/bridge-api.db
CONVENTIONS_FIXTURES_DIR=/app/fixtures

# --- Google OAuth (test client) ---
# Google Cloud Console → OAuth 2.0 Client IDs → create a second client for local.
# Authorized redirect URI: https://localhost/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe test mode ---
# Use sk_test_... and price_... from the Stripe dashboard in test mode.
# STRIPE_WEBHOOK_SECRET comes from `stripe listen --forward-to https://localhost/api/billing/webhook`
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_ID_MONTHLY=price_
STRIPE_PRICE_ID_ANNUAL=

BILLING_SUCCESS_URL=https://localhost/billing/success
BILLING_CANCEL_URL=https://localhost/billing/cancel
